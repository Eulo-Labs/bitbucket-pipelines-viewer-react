{
  "name": "@eulolabs/bitbucket-pipelines-viewer-react",
  "version": "0.2.4",
  "packageManager": "pnpm@10.30.3",
  "description": "Interactive React component for visualizing Bitbucket Pipelines YAML configurations as flow graphs",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/index.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite serve demo",
    "build": "vite build",
    "build:demo": "vite build --config vite.demo.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:a11y": "pa11y-ci",
    "lint:a11y:local": "./bin/run-a11y-tests-local",
    "fixstyle": "prettier '**/*.{ts,tsx,js,jsx,json,md,yaml,yml}' --write",
    "prepare": "husky",
    "publish-patch": "pnpm version patch && git push --follow-tags",
    "publish-minor": "pnpm version minor && git push --follow-tags"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,json,md,yaml,yml}": [
      "pnpm fixstyle"
    ]
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@atlaskit/tokens": "^11.0.1",
    "dagre": "^0.8.5",
    "js-yaml": "^4.1.1",
    "react-syntax-highlighter": "^16.1.1",
    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@atlaskit/css-reset": "^7.3.12",
    "@eslint/js": "^9.39.3",
    "@types/dagre": "^0.7.54",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.3.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "pa11y-ci": "^4.0.1",
    "prettier": "^3.8.1",
    "puppeteer": "^24.37.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "bitbucket",
    "pipelines",
    "viewer",
    "react",
    "yaml",
    "ci-cd",
    "visualization",
    "flow-graph"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Eulo-Labs/bitbucket-pipelines-viewer-react"
  },
  "pnpm": {
    "overrides": {
      "minimatch": "^10.2.3",
      "serve>ajv": ">=8.18.0"
    }
  }
}
