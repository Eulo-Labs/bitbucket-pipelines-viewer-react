#!/bin/bash
set -e

SKIP_BUILD=false

for arg in "$@"; do
  case $arg in
    --skip-build)
      SKIP_BUILD=true
      shift
      ;;
  esac
done

if [ "$SKIP_BUILD" = false ]; then
  pnpm run build:demo
  mkdir -p tmp-serve/bitbucket-pipelines-viewer-react
  cp -r dist-demo/* tmp-serve/bitbucket-pipelines-viewer-react/
fi

pnpm exec serve tmp-serve -l 3000 -s &
sleep 3
pnpm run lint:a11y
pkill -f 'serve tmp-serve'
