#!/bin/bash
set -e

SKIP_BUILD=false

for arg in "$@"; do
  case $arg in
    --skip-build)
      SKIP_BUILD=true
      shift
      ;;
  esac
done

if [ "$SKIP_BUILD" = false ]; then
  pnpm run build:demo
fi

mkdir -p tmp-serve/bitbucket-pipelines-viewer-react
cp -r dist-demo/* tmp-serve/bitbucket-pipelines-viewer-react/

pnpm exec http-server tmp-serve -p 3000 --silent &
SERVER_PID=$!
cleanup() { kill $SERVER_PID 2>/dev/null; }
trap cleanup EXIT
sleep 3
pnpm run lint:a11y
